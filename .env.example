# Jira Configuration
JIRA_BASE_URL=add URL here
JIRA_USERNAME=add email here
JIRA_API_TOKEN=add secret here
JIRA_PROJECT_KEY=add project key here
JIRA_BOARD_ID=add board id here
JIRA_STORY_STATUS=Ready for Deployment

# ServiceNow Configuration
SN_INSTANCE_URL=add URL here
SN_USERNAME=add username here
SN_PASSWORD=add secret here
SN_TABLE=sn_chg_management_update_set

# Teams Configuration
TEAMS_WEBHOOK_URL=add secret here

# Agent Configuration
AGENT_NAME=Jira-ServiceNow Deployment Agent
LOG_LEVEL=INFO
RUN_ON_THURSDAY=True
RUN_TIME=09:00
DRY_RUN=False

# State & Storage
STATE_FILE_PATH=./state/agent_state.json
LOG_FILE_PATH=./logs/agent.log
