# Jira Configuration
JIRA_BASE_URL=https://tomtom.atlassian.net/
JIRA_USERNAME=your.email@tomtom.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=CET
JIRA_BOARD_ID=14610
JIRA_STORY_STATUS=Ready for Deployment

# ServiceNow Configuration
SN_INSTANCE_URL=https://tomtomtest2.service-now.com
SN_USERNAME=your_servicenow_username
SN_PASSWORD=your_servicenow_password
SN_TABLE=sys_update_set

# Slack Configuration
SLACK_WEBHOOK_URL=https://example.com/slack-webhook-url

# Confluence Configuration
# Enable to auto-create/update monthly sprint deployment pages.
CONFLUENCE_ENABLED=True
CONFLUENCE_BASE_URL=https://tomtom.atlassian.net/wiki
CONFLUENCE_EMAIL=your.email@tomtom.com
CONFLUENCE_API_TOKEN=your_confluence_api_token
CONFLUENCE_SPACE_KEY=ITSM
CONFLUENCE_PARENT_PAGE_ID=644328917

# Agent Configuration
AGENT_NAME=Jira-ServiceNow Deployment Agent
LOG_LEVEL=INFO
RUN_ON_THURSDAY=True
RUN_TIME=03:30
DRY_RUN=False

# State & Storage
STATE_FILE_PATH=./state/agent_state.json
LOG_FILE_PATH=./logs/agent.log

# Scheduling notes
# - Set RUN_ON_THURSDAY=True to run the agent automatically on Thursdays.
# - RUN_TIME controls the scheduled execution time in HH:MM format.
# - This environment runs in UTC. For 09:00 AM IST, set RUN_TIME=03:30.
# - If you want only a one-time dry run, set DRY_RUN=True.
# - Use `python main.py --schedule` to keep the process running and execute on Thursdays.
# - Or use a system cron job for Thursday runs if you prefer not to keep the scheduler process active.
